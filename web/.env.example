NEXT_PUBLIC_SANITY_PROJECT_ID=z4yj6bjg
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-02-01
# Optional: a Viewer token enables draft previews. Leave unset for public reads.
SANITY_API_READ_TOKEN=
# Required for the shop's reservation cart (/api/reservations) and the one-off
# /api/migrate-images route. Needs Editor permissions.
SANITY_WRITE_TOKEN=
# Required for the weekly Google rating sync (/api/cron/update-google-rating,
# see vercel.json). Needs "Places API (New)" enabled. Leave unset and the
# "Rated X.X on Google" line falls back to the static text stored in Sanity.
GOOGLE_PLACES_API_KEY=
# Optional but recommended: any random string. Once set as a Vercel project
# env var, Vercel automatically sends it as a Bearer token on cron requests,
# which the route checks to reject requests from anyone else. Leave unset to
# skip auth (fine for local dev, not recommended in production).
CRON_SECRET=
